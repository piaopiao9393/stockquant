# StockQuant 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ============================================
# 数据源配置
# ============================================
# 默认数据源: akshare (免费) / tushare (需积分)
DATA_DEFAULT_SOURCE=akshare

# Tushare 数据配置 (如使用tushare则必填)
TUSHARE_TOKEN=your_tushare_token_here

# ============================================
# 数据库配置 (可选，默认SQLite)
# ============================================
# DATABASE_URL=sqlite:///data_storage/stockquant.db

# ============================================
# 交易配置 (可选)
# ============================================
# 交易模式: paper(模拟)/live(实盘)
TRADING_MODE=paper
# 初始资金
INITIAL_CASH=50000
# 佣金费率
COMMISSION_RATE=0.0003

# ============================================
# 风控配置 (可选)
# ============================================
MAX_POSITION_PCT=0.25
MAX_TOTAL_POSITION=0.80
MAX_DAILY_LOSS_PCT=0.05
MAX_DRAWDOWN_PCT=0.15

# ============================================
# 邮件通知配置 (用于发送交易建议)
# ============================================
# SMTP服务器 (QQ邮箱示例)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_password

# 收件人列表 (逗号分隔)
EMAIL_TO=your_email@qq.com,another@example.com

# ============================================
# 日志级别 (DEBUG/INFO/WARNING/ERROR)
# ============================================
LOG_LEVEL=INFO

# ============================================
# 数据更新设置
# ============================================
AUTO_UPDATE=true
UPDATE_TIME=15:35
